{
  "name": "root",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "bun scripts/test/run.ts",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check:lines": "bun scripts/check-code-lines.ts packages backend apps scripts",
    "check:lines:cli": "bun scripts/check-code-lines.ts packages/core/cli packages/cli/support packages/cli/app packages/cli/kit packages/cli/module packages/cli/codegen packages/cli/damat",
    "check:lines:installer": "bun scripts/check-code-lines.ts packages/installer",
    "check:codegen-boundaries": "bun scripts/check-codegen-boundaries.ts",
    "check-types": "turbo run check-types",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "bun run build && bun scripts/publish-packages.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "oxlint": "^1.73.0",
    "prettier": "^3.7.4",
    "turbo": "^2.8.10",
    "typescript": "5.9.2"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "backend/*",
    "modules/*",
    "packages/*",
    "packages/auth/*",
    "packages/cli/*",
    "packages/core/*",
    "packages/orm/*"
  ]
}
