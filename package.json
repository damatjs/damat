{
  "name": "root",
  "private": true,
  "scripts": {
    "build": "turbo run build --concurrency=1",
    "dev": "turbo run dev",
    "test": "bun scripts/test/run.ts",
    "test:sites": "bun scripts/test/sites.ts",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check:lines": "bun scripts/check-code-lines.ts packages provider backend apps scripts e2e",
    "check:lines:cli": "bun scripts/check-code-lines.ts packages/core/cli packages/cli/support packages/cli/app packages/cli/kit packages/cli/module packages/cli/codegen packages/cli/damat",
    "check:lines:installer": "bun scripts/check-code-lines.ts packages/installer",
    "check:codegen-boundaries": "bun scripts/check-codegen-boundaries.ts",
    "check-types": "turbo run check-types",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "check:secrets": "bun scripts/check-secrets.ts",
    "check:deployment-security": "bun scripts/check-deployment-security.ts",
    "check:release-clean": "bun scripts/check-release-clean.ts",
    "check:security": "bun audit && bun run check:secrets && bun run check:deployment-security",
    "check:release": "bun run check:release-clean && bun run lint --force && bun run check-types --force && bun run build --force && bun run test && bun run check:security",
    "release": "bun run build && bun scripts/publish-packages.ts"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "1.61.1",
    "oxlint": "^1.73.0",
    "prettier": "^3.7.4",
    "turbo": "2.9.14",
    "typescript": "5.9.2"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "backend/*",
    "modules/*",
    "packages/*",
    "packages/cli/*",
    "packages/core/*",
    "packages/orm/*",
    "provider/*"
  ]
}
