# =============================================================================
# DATABASE
# =============================================================================
DATABASE_URL="postgresql://postgres:Password@0.0.0.0:5432/embeddings?schema=public"

# =============================================================================
# REDIS (for caching, rate limiting, sessions)
# =============================================================================
REDIS_URL="redis://localhost:6379"

# =============================================================================
# CDN
# =============================================================================
CDN_BASE_URL=""

# =============================================================================
# SERVER
# =============================================================================
PORT=6000
NODE_ENV=development
API_VERSION="v1"

# Base URL for the API (used for callbacks, webhooks, etc.)
API_BASE_URL="http://localhost:6000"

# =============================================================================
# AUTHENTICATION (Better Auth)
# =============================================================================
# Secret key for signing cookies and tokens (generate with: openssl rand -base64 32)
# Minimum 32 characters required
BETTER_AUTH_SECRET="your-super-secret-key-min-32-chars-here"

# Base URL for Better Auth (used for OAuth callbacks, etc.)
BETTER_AUTH_URL="http://localhost:3000"

# Session configuration
SESSION_MAX_AGE=604800  # 7 days in seconds
SESSION_UPDATE_AGE=86400  # 1 day - when to refresh session

# OAuth Providers (optional - uncomment to enable)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""

# =============================================================================
# ADMIN
# =============================================================================
# Admin secret for internal API key management (legacy - prefer auth)
ADMIN_SECRET="your-secure-admin-secret-here"

# Super admin email (first user with this email becomes super admin)
SUPER_ADMIN_EMAIL="admin@example.com"

# =============================================================================
# STRIPE (Billing)
# =============================================================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# =============================================================================
# CORS
# =============================================================================
# Comma-separated origins, or * for all
CORS_ORIGIN="http://localhost:3001,http://localhost:5173"

# =============================================================================
# RATE LIMITING
# =============================================================================
# Default rate limits (can be overridden per plan)
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_REQUESTS_PER_HOUR=1000
RATE_LIMIT_REQUESTS_PER_DAY=10000

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL="debug"  # debug, info, warn, error
LOG_FORMAT="pretty"  # json, pretty, simple

# File logging (optional)
LOG_FILE="true"  # Set to "true" to enable file logging
LOG_DIR="logs"  # Directory for log files

# =============================================================================
# EMAIL (for notifications - optional)
# =============================================================================
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASS=""
# EMAIL_FROM="noreply@example.com"

# =============================================================================
# WEBHOOKS
# =============================================================================
# Timeout for webhook deliveries (ms)
WEBHOOK_TIMEOUT_MS=30000
WEBHOOK_MAX_RETRIES=3
