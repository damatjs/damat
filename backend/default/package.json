{
  "name": "@damatjs/default",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun ./node_modules/@damatjs/damat-cli/dist/cli.js dev",
    "build": "bun ./node_modules/@damatjs/damat-cli/dist/cli.js build",
    "start": "bun ./node_modules/@damatjs/damat-cli/dist/cli.js start",
    "codegen": "bun ./node_modules/@damatjs/damat-cli/dist/cli.js codegen",
    "db:setup": "bun ./node_modules/@damatjs/orm-cli/dist/bin.js database:setup",
    "db:migrate": "bun ./node_modules/@damatjs/orm-cli/dist/bin.js migrate:up",
    "db:status": "bun ./node_modules/@damatjs/orm-cli/dist/bin.js migrate:status",
    "db:create": "bun ./node_modules/@damatjs/orm-cli/dist/bin.js migrate:create",
    "ops:validate": "bun ops/validate-environment.ts",
    "ops:env": "bun ops/create-compose-env.ts",
    "ops:drill": "./ops/staging-drill.sh",
    "ops:database": "bun ops/database-acceptance.ts",
    "ops:redis": "bun ops/redis-acceptance.ts",
    "ops:workers": "bun ops/worker-health.ts",
    "ops:smoke": "bun ops/smoke.ts",
    "ops:load": "bun ops/load.ts",
    "ops:rollback": "bun ops/rollback.ts",
    "test": "bun run test:unit && bun run test:recovery",
    "test:unit": "bun test --isolate --path-ignore-patterns=tests/recovery.test.ts",
    "test:recovery": "bun test --coverage-dir=coverage/recovery tests/recovery.test.ts",
    "test:watch": "bun test --watch",
    "test:coverage": "bun run test",
    "lint": "oxlint src tests ops damat.config.ts",
    "lint:fix": "oxlint --fix src tests ops damat.config.ts",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@damatjs/damat-cli": "1.0.2",
    "@damatjs/deps": "1.0.2",
    "@damatjs/events": "1.0.2",
    "@damatjs/framework": "1.0.2",
    "@damatjs/jobs": "1.0.2",
    "@damatjs/logger": "1.0.2",
    "@damatjs/orm-cli": "1.0.2",
    "@damatjs/orm-model": "1.0.2",
    "@damatjs/orm-pg": "1.0.2",
    "@damatjs/orm-processor": "1.0.2",
    "@damatjs/pipelines": "1.0.2",
    "@damatjs/services": "1.0.2",
    "@damatjs/types": "1.0.2",
    "@damatjs/workflow-engine": "1.0.2"
  },
  "devDependencies": {
    "@damatjs/provider-auth": "1.0.2",
    "@damatjs/provider-payment": "1.0.2",
    "@damatjs/provider-subscription": "1.0.2",
    "@damatjs/typescript-config": "*",
    "@types/bun": "1.3.9",
    "@types/node": "^22.10.2",
    "bun-types": "^1.3.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}