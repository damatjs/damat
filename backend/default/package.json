{
  "name": "@damatjs/default",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "damat dev",
    "build": "damat build",
    "start": "damat start",
    "codegen": "damat codegen",
    "db:setup": "damat-orm database:setup",
    "db:migrate": "damat-orm migrate:up",
    "db:status": "damat-orm migrate:status",
    "db:create": "damat-orm migrate:create",
    "ops:validate": "bun ops/validate-environment.ts",
    "ops:env": "bun ops/create-compose-env.ts",
    "ops:drill": "./ops/staging-drill.sh",
    "ops:database": "bun ops/database-acceptance.ts",
    "ops:redis": "bun ops/redis-acceptance.ts",
    "ops:workers": "bun ops/worker-health.ts",
    "ops:smoke": "bun ops/smoke.ts",
    "ops:load": "bun ops/load.ts",
    "ops:rollback": "bun ops/rollback.ts",
    "test": "bun run test:unit && bun run test:recovery",
    "test:unit": "bun test --path-ignore-patterns=tests/recovery.test.ts",
    "test:recovery": "bun test --coverage-dir=coverage/recovery tests/recovery.test.ts",
    "test:watch": "bun test --watch",
    "test:coverage": "bun run test",
    "lint": "oxlint src tests damat.config.ts",
    "lint:fix": "oxlint --fix src tests damat.config.ts",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@damatjs/damat-cli": "*",
    "@damatjs/deps": "*",
    "@damatjs/events": "*",
    "@damatjs/framework": "*",
    "@damatjs/jobs": "*",
    "@damatjs/logger": "*",
    "@damatjs/orm-cli": "*",
    "@damatjs/orm-model": "*",
    "@damatjs/orm-pg": "*",
    "@damatjs/orm-processor": "*",
    "@damatjs/pipelines": "*",
    "@damatjs/services": "*",
    "@damatjs/types": "*",
    "@damatjs/workflow-engine": "*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "*",
    "@types/bun": "1.3.9",
    "@types/node": "^22.10.2",
    "bun-types": "^1.3.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
