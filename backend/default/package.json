{
  "name": "@damatjs/default",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "damat dev",
    "build": "damat build",
    "start": "damat start",
    "codegen": "damat-orm generate:types",
    "db:migrate": "damat-orm migrate:up",
    "db:status": "damat-orm migrate:status",
    "db:create": "damat-orm migrate:create",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@damatjs/logger": "*",
    "@damatjs/services": "*",
    "@damatjs/types": "*",
    "@damatjs/deps": "*",
    "@damatjs/damat-cli": "*",
    "@damatjs/framework": "*",
    "@damatjs/workflow-engine": "*",
    "@damatjs/orm-cli": "*",
    "@damatjs/orm-model": "*",
    "@damatjs/orm-processor": "*",
    "@damatjs/orm-pg": "*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "*",
    "@types/bun": "1.3.9",
    "@types/node": "^22.10.2",
    "bun-types": "^1.3.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
