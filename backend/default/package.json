{
  "name": "@damatjs/default",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "damat dev",
    "build": "damat build",
    "start": "damat start",
    "codegen": "damat codegen",
    "db:migrate": "damat-orm migrate:up",
    "db:status": "damat-orm migrate:status",
    "db:create": "damat-orm migrate:create",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "lint": "oxlint src tests damat.config.ts",
    "lint:fix": "oxlint --fix src tests damat.config.ts",
    "check-types": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "dependencies": {
    "@damatjs/damat-cli": "*",
    "@damatjs/deps": "*",
    "@damatjs/events": "*",
    "@damatjs/framework": "*",
    "@damatjs/jobs": "*",
    "@damatjs/logger": "*",
    "@damatjs/orm-cli": "*",
    "@damatjs/orm-model": "*",
    "@damatjs/orm-pg": "*",
    "@damatjs/orm-processor": "*",
    "@damatjs/pipelines": "*",
    "@damatjs/services": "*",
    "@damatjs/types": "*",
    "@damatjs/workflow-engine": "*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "*",
    "@types/bun": "1.3.9",
    "@types/node": "^22.10.2",
    "bun-types": "^1.3.9",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
