{
  "name": "@damatjs/link",
  "description": "Cross-module links for Damat — define relationships between two modules, generate the junction table, migrate it, and query linked records across modules.",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/damatjs/damat",
    "directory": "packages/link"
  },
  "license": "MIT",
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/tests",
    "!dist/**/__fixtures__"
  ],
  "author": "Abel Lamesgen",
  "dependencies": {
    "@damatjs/deps": "workspace:*",
    "@damatjs/orm-model": "workspace:*",
    "@damatjs/orm-pg": "workspace:*",
    "@damatjs/orm-type": "workspace:*",
    "@damatjs/services": "workspace:*",
    "@damatjs/logger": "workspace:*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "workspace:*",
    "@damatjs/orm-connector": "workspace:*",
    "@damatjs/orm-migration": "workspace:*",
    "@damatjs/orm-processor": "workspace:*",
    "@damatjs/schema-codegen": "workspace:*",
    "@types/bun": "1.3.9",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc && tsc-alias",
    "dev": "bun run build --watch",
    "watch": "tsc --watch",
    "test": "bun ../../scripts/test/package.ts DAMAT_LINK_DATABASE_URL",
    "prepublishOnly": "test -f dist/index.js || (echo 'Error: dist/index.js not found. Run bun run build first.' && exit 1)",
    "lint": "oxlint src"
  }
}
