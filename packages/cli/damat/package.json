{
  "name": "@damatjs/damat-cli",
  "description": "Damat CLI - Development and build tool for Damat.js",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "damat": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/damatjs/damat",
    "directory": "packages/cli/damat"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "author": "Abel Lamesgen",
  "dependencies": {
    "@damatjs/cli": "workspace:*",
    "@damatjs/cli-app": "workspace:*",
    "@damatjs/cli-codegen": "workspace:*",
    "@damatjs/cli-kit": "workspace:*",
    "@damatjs/cli-module": "workspace:*",
    "@damatjs/logger": "workspace:*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "workspace:*",
    "@types/bun": "1.3.9",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && bun scripts/embedVersion.ts && tsc && chmod +x dist/cli.js",
    "check-types": "tsc --noEmit",
    "test": "bun test",
    "dev": "bun run build --watch",
    "postinstall": "chmod +x dist/cli.js || true",
    "prepublishOnly": "test -f dist/cli.js || (echo 'Error: dist/cli.js is missing. Run bun run build first.' && exit 1)",
    "lint": "oxlint src"
  }
}
