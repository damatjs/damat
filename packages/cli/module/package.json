{
  "name": "@damatjs/cli-module",
  "description": "Damat module authoring and installation CLI capability",
  "version": "1.0.2",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/damatjs/damat",
    "directory": "packages/cli/module"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "dependencies": {
    "@damatjs/cli": "workspace:*",
    "@damatjs/cli-support": "workspace:*",
    "@damatjs/framework": "workspace:*",
    "@damatjs/installer": "workspace:*",
    "@damatjs/load-env": "workspace:*",
    "@damatjs/module": "workspace:*",
    "@damatjs/orm-cli": "workspace:*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "workspace:*",
    "@types/bun": "1.3.9",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && bun scripts/embedAgents.ts && tsc",
    "check-types": "tsc --noEmit",
    "test": "bun test",
    "lint": "oxlint src scripts"
  }
}
