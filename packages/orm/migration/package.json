{
  "name": "@damatjs/orm-migration",
  "description": "Damatjs orm utils definition",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "damat-migrate": "./dist/cli/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./bin": {
      "default": "./dist/cli/bin.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__",
    "!dist/**/__mocks__"
  ],
  "author": "Abel Lamesgen",
  "dependencies": {
    "@damatjs/deps": "*",
    "@damatjs/orm-model": "*",
    "@damatjs/orm-processor": "*",
    "@damatjs/types": "*",
    "dotenv": "^17.3.1",
    "reflect-metadata": "^0.2.2",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "*",
    "@types/bun": "1.3.9",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc",
    "postbuild": "chmod +x dist/cli/bin.js",
    "dev": "bun run build --watch",
    "watch": "tsc --watch",
    "test": "exit 0"
  }
}
