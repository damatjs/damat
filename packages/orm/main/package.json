{
    "name": "@damatjs/orm",
    "description": "Damat ORM",
    "version": "0.0.3",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./model": {
            "types": "./dist/model.d.ts",
            "default": "./dist/model.js"
        },
        "./connector": {
            "types": "./dist/connector.d.ts",
            "default": "./dist/connector.js"
        },
        "./migration": {
            "types": "./dist/migration.d.ts",
            "default": "./dist/migration.js"
        },
        "./processor": {
            "types": "./dist/processor.d.ts",
            "default": "./dist/processor.js"
        },
        "./pg": {
            "types": "./dist/pg.d.ts",
            "default": "./dist/pg.js"
        }
    },
    "engines": {
        "bun": ">=1.1.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/damatjs/damat",
        "directory": "packages/core/types"
    },
    "files": [
        "dist",
        "!dist/**/__tests__",
        "!dist/**/__fixtures__",
        "!dist/**/__mocks__"
    ],
    "author": "Abel Lamesgen",
    "license": "MIT",
    "dependencies": {
        "@damatjs/orm-migration": "*",
        "@damatjs/orm-connector": "*",
        "@damatjs/orm-model": "*",
        "@damatjs/orm-processor": "*",
        "@damatjs/orm-pg": "*",
        "@damatjs/deps": "*"
    },
    "devDependencies": {
        "@damatjs/typescript-config": "*",
        "@types/bun": "1.3.9",
        "typescript": "5.9.2"
    },
    "scripts": {
        "build": "rm -rf dist tsconfig.tsbuildinfo && tsc",
        "watch": "tsc --watch",
        "test": "exit 0"
    }
}