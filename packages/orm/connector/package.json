{
  "name": "@damatjs/orm-connector",
  "description": "Damatjs pg connection manager",
  "version": "1.0.0+0.2",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/damatjs/damat",
    "directory": "packages/orm/connector"
  },
  "license": "MIT",
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__",
    "!dist/**/__mocks__",
    "!dist/**/__snapshots__"
  ],
  "author": "Abel Lamesgen",
  "dependencies": {
    "@damatjs/deps": "workspace:*",
    "@damatjs/orm-type": "workspace:*",
    "@damatjs/types": "workspace:*",
    "@damatjs/logger": "workspace:*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "workspace:*",
    "@types/bun": "1.3.9",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc -p tsconfig.json",
    "dev": "bun run build --watch",
    "watch": "tsc --watch",
    "test": "bun test ./src",
    "prepublishOnly": "test -f dist/index.js || (echo 'Error: dist/index.js not found. Run bun run build first.' && exit 1)",
    "lint": "oxlint src"
  }
}
