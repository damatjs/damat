{
  "name": "@damatjs/orm-connector",
  "description": "Damatjs pg connection manager",
  "version": "0.0.10",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__",
    "!dist/**/__mocks__",
    "!dist/**/__snapshots__"
  ],
  "author": "Abel Lamesgen",
  "dependencies": {
    "@damatjs/deps": "*",
    "@damatjs/orm-type": "*",
    "@damatjs/types": "*",
    "@damatjs/logger": "*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "*",
    "@types/bun": "1.3.9",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc -p tsconfig.json",
    "dev": "bun run build --watch",
    "watch": "tsc --watch",
    "test": "bun test ./src"
  }
}