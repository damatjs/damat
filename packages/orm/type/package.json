{
    "name": "@damatjs/orm-type",
    "description": "Damat ORM shared types",
    "version": "0.6.0",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "engines": {
        "bun": ">=1.1.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/damatjs/damat",
        "directory": "packages/orm/type"
    },
    "files": [
        "dist",
        "!dist/**/__tests__",
        "!dist/**/__fixtures__",
        "!dist/**/__mocks__"
    ],
    "author": "Abel Lamesgen",
    "license": "MIT",
    "dependencies": {
        "@damatjs/deps": "workspace:*"
    },
    "devDependencies": {
        "@damatjs/typescript-config": "workspace:*",
        "@types/bun": "1.3.9",
        "typescript": "5.9.2"
    },
    "scripts": {
        "build": "rm -rf dist tsconfig.tsbuildinfo && tsc",
        "watch": "tsc --watch",
        "test": "bun test",
        "prepublishOnly": "test -f dist/index.js || (echo 'Error: dist/index.js not found. Run bun run build first.' && exit 1)",
        "lint": "oxlint src"
    }
}
