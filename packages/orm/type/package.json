{
    "name": "@damatjs/orm-type",
    "description": "Damat ORM shared types",
    "version": "0.0.8",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "engines": {
        "bun": ">=1.1.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "files": [
        "dist",
        "!dist/**/__tests__",
        "!dist/**/__fixtures__",
        "!dist/**/__mocks__"
    ],
    "author": "Abel Lamesgen",
    "license": "MIT",
    "dependencies": {
        "@damatjs/deps": "*"
    },
    "devDependencies": {
        "@damatjs/typescript-config": "*",
        "@types/bun": "1.3.9",
        "typescript": "5.9.2"
    },
    "scripts": {
        "build": "rm -rf dist tsconfig.tsbuildinfo && tsc",
        "watch": "tsc --watch",
        "test": "exit 0"
    }
}