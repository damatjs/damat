{
  "name": "@damatjs/orm-model",
  "description": "Damatjs orm model definition",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "files": [
    "dist",
    "!dist/tests",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__",
    "!dist/**/__mocks__",
    "!dist/**/__snapshots__"
  ],
  "author": "Abel Lamesgen",
  "dependencies": {
    "@damatjs/deps": "*",
    "@damatjs/types": "*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "*",
    "@types/bun": "1.3.9",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc",
    "dev": "bun run build --watch",
    "watch": "tsc --watch",
    "snapshot": "bun run scripts/generate-snapshots",
    "codegen": "bun run scripts/generate-types",
    "test": "bun run snapshot && bun test ./src/tests/**.test.ts"
  }
}
