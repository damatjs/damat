{
  "name": "@damatjs/orm-cli",
  "description": "Damatjs ORM CLI - unified command line interface for codegen and migrations",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "damat-orm": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "files": [
    "dist",
    "!dist/tests",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__",
    "!dist/**/__mocks__",
    "!dist/**/__snapshots__"
  ],
  "author": "Abel Lamesgen",
  "dependencies": {
    "@damatjs/deps": "*",
    "@damatjs/logger": "*",
    "@damatjs/orm-codegen": "*",
    "@damatjs/orm-migration": "*",
    "@damatjs/orm-processor": "*",
    "@damatjs/orm-model": "*",
    "@damatjs/orm-type": "*",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "*",
    "@types/bun": "1.3.9",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc",
    "postbuild": "chmod +x dist/bin.js",
    "dev": "bun run build --watch",
    "watch": "tsc --watch",
    "test": "bun test src/tests/"
  }
}