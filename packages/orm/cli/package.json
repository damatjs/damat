{
  "name": "@damatjs/orm-cli",
  "description": "Damatjs ORM CLI - database migration commands",
  "version": "1.0.2",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "damat-orm": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/damatjs/damat",
    "directory": "packages/orm/cli"
  },
  "license": "MIT",
  "files": [
    "dist",
    "!dist/tests",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__",
    "!dist/**/__mocks__",
    "!dist/**/__snapshots__"
  ],
  "author": "Abel Lamesgen",
  "dependencies": {
    "@damatjs/cli": "workspace:*",
    "@damatjs/deps": "workspace:*",
    "@damatjs/durability": "workspace:*",
    "@damatjs/events": "workspace:*",
    "@damatjs/logger": "workspace:*",
    "@damatjs/installer": "workspace:*",
    "@damatjs/jobs": "workspace:*",
    "@damatjs/pipelines": "workspace:*",
    "@damatjs/orm-migration": "workspace:*",
    "@damatjs/orm-processor": "workspace:*",
    "@damatjs/orm-model": "workspace:*",
    "@damatjs/orm-type": "workspace:*",
    "@damatjs/schema-codegen": "workspace:*",
    "@damatjs/link": "workspace:*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "workspace:*",
    "@types/bun": "1.3.9",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc && tsc-alias",
    "postbuild": "chmod +x dist/bin.js",
    "dev": "bun run build --watch",
    "watch": "tsc --watch",
    "test": "bun test src/tests/",
    "prepublishOnly": "test -f dist/bin.js || (echo 'Error: dist/bin.js not found. Run bun run build first.' && exit 1)",
    "lint": "oxlint src"
  }
}
