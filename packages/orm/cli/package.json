{
  "name": "@damatjs/orm-cli",
  "description": "Damatjs ORM CLI - database migration commands",
  "version": "0.3.7",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "damat-orm": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "!dist/tests",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__",
    "!dist/**/__mocks__",
    "!dist/**/__snapshots__"
  ],
  "author": "Abel Lamesgen",
  "dependencies": {
    "@damatjs/cli": "*",
    "@damatjs/codegen": "*",
    "@damatjs/deps": "*",
    "@damatjs/logger": "*",
    "@damatjs/orm-migration": "*",
    "@damatjs/orm-processor": "*",
    "@damatjs/orm-model": "*",
    "@damatjs/orm-type": "*",
    "@damatjs/link": "*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "*",
    "@types/bun": "1.3.9",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc && tsc-alias",
    "postbuild": "chmod +x dist/bin.js",
    "dev": "bun run build --watch",
    "watch": "tsc --watch",
    "test": "bun test src/tests/",
    "prepublishOnly": "test -f dist/bin.js || (echo 'Error: dist/bin.js not found. Run bun run build first.' && exit 1)"
  }
}