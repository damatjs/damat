{
  "name": "@damatjs/orm-pg",
  "description": "PostgreSQL ORM core for @damatjs - EntityManager, Repository pattern, and query execution",
  "version": "0.6.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/damatjs/damat",
    "directory": "packages/orm/pg"
  },
  "license": "MIT",
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__",
    "!dist/**/__mocks__"
  ],
  "author": "Abel Lamesgen",
  "dependencies": {
    "@damatjs/logger": "workspace:*",
    "@damatjs/orm-core": "workspace:*",
    "@damatjs/orm-model": "workspace:*",
    "@damatjs/orm-type": "workspace:*",
    "@damatjs/types": "workspace:*"
  },
  "devDependencies": {
    "@damatjs/deps": "workspace:*",
    "@damatjs/orm-processor": "workspace:*",
    "@damatjs/typescript-config": "workspace:*",
    "@types/bun": "1.3.9",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc && tsc-alias",
    "dev": "bun run build --watch",
    "watch": "tsc --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "test -f dist/index.js || (echo 'Error: dist/index.js not found. Run bun run build first.' && exit 1)"
  }
}
