{
  "name": "@damatjs/orm-pg",
  "description": "PostgreSQL ORM core for @damatjs - EntityManager, Repository pattern, and query execution",
  "version": "0.3.5",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__",
    "!dist/**/__mocks__"
  ],
  "author": "Abel Lamesgen",
  "dependencies": {
    "@damatjs/logger": "*",
    "@damatjs/orm-core": "*",
    "@damatjs/orm-model": "*",
    "@damatjs/orm-type": "*",
    "@damatjs/types": "*"
  },
  "devDependencies": {
    "@damatjs/deps": "*",
    "@damatjs/orm-processor": "*",
    "@damatjs/typescript-config": "*",
    "@types/bun": "1.3.9",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc && tsc-alias",
    "dev": "bun run build --watch",
    "watch": "tsc --watch",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  }
}
