{
  "name": "@damatjs/orm-core",
  "description": "Damat ORM core - database-agnostic registry, logging, and types",
  "version": "1.0.2",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/damatjs/damat",
    "directory": "packages/orm/core"
  },
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__",
    "!dist/**/__mocks__"
  ],
  "author": "Abel Lamesgen",
  "license": "MIT",
  "dependencies": {
    "@damatjs/logger": "workspace:*",
    "@damatjs/orm-model": "workspace:*",
    "@damatjs/orm-type": "workspace:*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "workspace:*",
    "@types/bun": "1.3.9",
    "typescript": "5.9.2"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc",
    "watch": "tsc --watch",
    "test": "bun test",
    "prepublishOnly": "test -f dist/index.js || (echo 'Error: dist/index.js not found. Run bun run build first.' && exit 1)",
    "lint": "oxlint src"
  }
}
