{
  "name": "@damatjs/auth-auth0",
  "description": "Auth0 provider adapter for Damat — verify Auth0 access tokens via JWKS and populate the request principal",
  "version": "0.6.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/damatjs/damat",
    "directory": "packages/auth/auth0"
  },
  "license": "MIT",
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__",
    "!dist/**/__mocks__"
  ],
  "author": "Abel Lamesgen",
  "dependencies": {
    "@damatjs/auth": "workspace:*",
    "@damatjs/deps": "workspace:*",
    "@damatjs/logger": "workspace:*"
  },
  "peerDependencies": {
    "jose": ">=5.0.0"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "workspace:*",
    "@types/bun": "1.3.9",
    "jose": "^5.9.6",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc",
    "watch": "tsc --watch",
    "test": "bun test",
    "lint": "oxlint src",
    "prepublishOnly": "test -f dist/index.js || (echo 'Error: dist/index.js not found. Run bun run build first.' && exit 1)"
  }
}
