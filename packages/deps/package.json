{
  "name": "@damatjs/deps",
  "version": "0.4.0",
  "description": "Dependencies for damatjs",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./effect": {
      "types": "./dist/effect.d.ts",
      "default": "./dist/effect.js"
    },
    "./pg": {
      "types": "./dist/pg.d.ts",
      "default": "./dist/pg.js"
    },
    "./hono": {
      "types": "./dist/hono.d.ts",
      "default": "./dist/hono.js"
    },
    "./uuid": {
      "types": "./dist/uuid.d.ts",
      "default": "./dist/uuid.js"
    },
    "./zod": {
      "types": "./dist/zod.d.ts",
      "import": "./dist/zod.js",
      "default": "./dist/zod.js"
    },
    "./ioredis": {
      "types": "./dist/ioredis.d.ts",
      "default": "./dist/ioredis.js"
    },
    "./nanoid": {
      "types": "./dist/nanoid.d.ts",
      "default": "./dist/nanoid.js"
    }
  },
  "author": "Abel Lamesgen",
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc --build",
    "test": "bun test"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "effect": "^3.19.18",
    "hono": "^4.12.0",
    "ioredis": "^5.9.3",
    "nanoid": "^5.1.6",
    "pg": "^8.21.0",
    "uuid": "^13.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "*",
    "@types/bun": "1.3.9",
    "@types/pg": "^8.16.0",
    "typescript": "^5.9.3"
  },
  "gitHead": "f4e64d965f2485219c313f9adb7f40ad89539eaf"
}
