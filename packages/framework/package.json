{
  "name": "@damatjs/framework",
  "description": "Damatjs framework for handling everything",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./entry": {
      "types": "./dist/entry.d.ts",
      "default": "./dist/entry.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "default": "./dist/router/index.js"
    },
    "./handlers": {
      "types": "./dist/handlers/index.d.ts",
      "default": "./dist/handlers/index.js"
    },
    "./bootstrap": {
      "types": "./dist/bootstrap/index.d.ts",
      "default": "./dist/bootstrap/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    },
    "./shutdown": {
      "types": "./dist/shutdown/index.d.ts",
      "default": "./dist/shutdown/index.js"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "default": "./dist/middleware/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "default": "./dist/services/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/damatjs/damat",
    "directory": "packages/framework"
  },
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__",
    "!dist/**/__mocks__"
  ],
  "author": "Abel Lamesgen",
  "dependencies": {
    "@damatjs/logger": "workspace:*",
    "@damatjs/provider-auth": "workspace:*",
    "@damatjs/installer": "workspace:*",
    "@damatjs/deps": "workspace:*",
    "@damatjs/durability": "workspace:*",
    "@damatjs/types": "workspace:*",
    "@damatjs/services": "workspace:*",
    "@damatjs/link": "workspace:*",
    "@damatjs/orm-connector": "workspace:*",
    "@damatjs/orm-type": "workspace:*",
    "@damatjs/workflow-engine": "workspace:*",
    "@damatjs/events": "workspace:*",
    "@damatjs/jobs": "workspace:*",
    "@damatjs/pipelines": "workspace:*",
    "@damatjs/provider": "workspace:*",
    "@damatjs/redis": "workspace:*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "workspace:*",
    "@types/bun": "1.3.9",
    "hono": "^4.12.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc",
    "dev": "bun run build --watch",
    "watch": "tsc --watch",
    "test": "bun src/tests/run.ts",
    "prepublishOnly": "test -f dist/index.js || (echo 'Error: dist/index.js not found. Run bun run build first.' && exit 1)",
    "lint": "oxlint src"
  }
}