{
  "name": "@damatjs/workflow-engine",
  "version": "1.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/damatjs/damat",
    "directory": "packages/workflow-engine"
  },
  "license": "MIT",
  "author": "Abel Lamesgen",
  "description": "Damatjs saga-style workflow engine built on Effect-TS",
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__",
    "!dist/**/__mocks__"
  ],
  "dependencies": {
    "@damatjs/logger": "workspace:*",
    "@damatjs/redis": "workspace:*",
    "@damatjs/deps": "workspace:*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "workspace:*",
    "@types/bun": "1.3.9",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc",
    "watch": "tsc --watch",
    "test": "bun test",
    "prepublishOnly": "test -f dist/index.js || (echo 'Error: dist/index.js not found. Run bun run build first.' && exit 1)",
    "lint": "oxlint src"
  }
}
