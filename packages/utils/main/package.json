{
  "name": "@damatjs/utils",
  "description": "Damatjs utils definition",
  "version": "0.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./env": {
      "types": "./dist/env/index.d.ts",
      "default": "./dist/env/index.js"
    },
    "./redis": {
      "types": "./dist/redis/index.d.ts",
      "default": "./dist/redis/index.js"
    },
    "./router": {
      "types": "./dist/router/index.d.ts",
      "default": "./dist/router/index.js"
    },
    "./config": {
      "types": "./dist/config/index.d.ts",
      "default": "./dist/config/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "license": "MIT",
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__",
    "!dist/**/__mocks__"
  ],
  "author": "Abel Lamesgen",
  "dependencies": {
    "@damatjs/utils-config": "*",
    "@damatjs/utils-env": "*",
    "@damatjs/utils-redis": "*",
    "@damatjs/utils-router": "*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "*",
    "@types/bun": "1.3.9",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc",
    "dev": "bun run build --watch",
    "watch": "tsc --watch",
    "test": "exit 0"
  }
}