{
  "name": "@damatjs/installer",
  "version": "1.0.0-beta.0",
  "description": "Headless transactional installer engine for Damat artifacts",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/damatjs/damat",
    "directory": "packages/installer"
  },
  "license": "MIT",
  "author": "Abel Lamesgen",
  "files": [
    "dist",
    "!dist/**/tests/**",
    "!dist/**/*.test.*"
  ],
  "devDependencies": {
    "@damatjs/typescript-config": "workspace:*",
    "@types/bun": "1.3.9",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc",
    "check-types": "tsc --noEmit",
    "watch": "tsc --watch",
    "test": "bun test",
    "lint": "oxlint src",
    "prepublishOnly": "test -f dist/index.js || (echo 'dist/index.js missing — run build first' && exit 1)"
  }
}
