{
  "name": "@damatjs/module",
  "version": "1.0.3",
  "description": "Damatjs module system — manifest contract, standalone dev/test harness, and registry tooling for self-contained modules",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/damatjs/damat",
    "directory": "packages/module"
  },
  "license": "MIT",
  "author": "Abel Lamesgen",
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__",
    "!dist/**/__mocks__"
  ],
  "dependencies": {
    "@damatjs/installer": "workspace:*",
    "@damatjs/deps": "workspace:*",
    "@damatjs/durability": "workspace:*",
    "@damatjs/events": "workspace:*",
    "@damatjs/framework": "workspace:*",
    "@damatjs/jobs": "workspace:*",
    "@damatjs/logger": "workspace:*",
    "@damatjs/module-generator": "workspace:*",
    "@damatjs/orm-connector": "workspace:*",
    "@damatjs/orm-migration": "workspace:*",
    "@damatjs/orm-model": "workspace:*",
    "@damatjs/orm-type": "workspace:*",
    "@damatjs/services": "workspace:*",
    "@damatjs/workflow-engine": "workspace:*",
    "@damatjs/pipelines": "workspace:*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "workspace:*",
    "@types/bun": "1.3.9",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc",
    "watch": "tsc --watch",
    "test": "bun test",
    "prepublishOnly": "test -f dist/index.js || (echo 'dist/index.js missing — run build before publishing' && exit 1)",
    "lint": "oxlint src"
  }
}
