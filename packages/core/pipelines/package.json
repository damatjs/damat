{
  "name": "@damatjs/pipelines",
  "description": "Durable PostgreSQL orchestration across jobs, events, and workflows",
  "version": "1.0.3",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./migrations": {
      "types": "./dist/migrations/index.d.ts",
      "default": "./dist/migrations/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/damatjs/damat",
    "directory": "packages/core/pipelines"
  },
  "license": "MIT",
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__"
  ],
  "author": "Abel Lamesgen",
  "dependencies": {
    "@damatjs/deps": "workspace:*",
    "@damatjs/durability": "workspace:*",
    "@damatjs/events": "workspace:*",
    "@damatjs/jobs": "workspace:*",
    "@damatjs/logger": "workspace:*",
    "@damatjs/workflow-engine": "workspace:*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "workspace:*",
    "@types/bun": "1.3.9",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc",
    "watch": "tsc --watch",
    "test": "bun ../../../scripts/test/package.ts DAMAT_PIPELINES_DATABASE_URL --max-concurrency=1",
    "lint": "oxlint src",
    "prepublishOnly": "test -f dist/index.js || (echo 'Error: dist/index.js not found. Run bun run build first.' && exit 1)"
  }
}
