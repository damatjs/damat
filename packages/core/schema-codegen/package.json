{
  "name": "@damatjs/schema-codegen",
  "description": "Pure TypeScript and Zod source generation from Damat module schemas",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/damatjs/damat",
    "directory": "packages/core/schema-codegen"
  },
  "files": [
    "dist",
    "!dist/**/tests"
  ],
  "license": "MIT",
  "dependencies": {
    "@damatjs/orm-type": "workspace:*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "workspace:*",
    "@types/bun": "1.3.9",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc && tsc-alias",
    "test": "bun test ./src/tests",
    "lint": "oxlint src"
  }
}
