{
  "name": "@damatjs/codegen",
  "description": "Damatjs codegen — agnostic type + zod + CRUD scaffold generation",
  "version": "1.0.1",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "!dist/tests",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__",
    "!dist/**/__mocks__",
    "!dist/**/__snapshots__"
  ],
  "author": "Abel Lamesgen",
  "peerDependencies": {
    "@damatjs/logger": "*"
  },
  "dependencies": {
    "@damatjs/orm-migration": "*",
    "@damatjs/orm-model": "*",
    "@damatjs/orm-type": "*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "*",
    "@damatjs/logger": "*",
    "@types/bun": "1.3.9",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc && tsc-alias",
    "dev": "bun run build --watch",
    "watch": "tsc --watch",
    "test": "bun test ./src/tests"
  }
}