{
  "name": "@damatjs/codegen",
  "description": "Deprecated compatibility facade for Damat code generation",
  "version": "2.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/types/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/damatjs/damat",
    "directory": "packages/core/codegen"
  },
  "license": "MIT",
  "files": [
    "dist",
    "!dist/tests",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__",
    "!dist/**/__mocks__",
    "!dist/**/__snapshots__"
  ],
  "author": "Abel Lamesgen",
  "keywords": [
    "deprecated",
    "@damatjs/schema-codegen",
    "@damatjs/module-generator"
  ],
  "dependencies": {
    "@damatjs/module-generator": "workspace:*",
    "@damatjs/schema-codegen": "workspace:*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "workspace:*",
    "@types/bun": "1.3.9",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc && tsc-alias",
    "dev": "bun run build --watch",
    "watch": "tsc --watch",
    "test": "bun test ./src/tests && tsc -p src/tests/tsconfig.json",
    "prepublishOnly": "test -f dist/index.js || (echo 'Error: dist/index.js not found. Run bun run build first.' && exit 1)",
    "lint": "oxlint src"
  }
}
