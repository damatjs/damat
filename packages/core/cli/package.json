{
  "name": "@damatjs/cli",
  "description": "General CLI framework for DamatJS",
  "version": "0.3.2",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "!dist/**/__tests__",
    "!dist/**/__fixtures__",
    "!dist/**/__mocks__"
  ],
  "author": "Abel Lamesgen",
  "license": "MIT",
  "dependencies": {
    "cac": "^6.7.14",
    "dotenv": "^17.3.1",
    "@damatjs/logger": "*"
  },
  "devDependencies": {
    "@damatjs/typescript-config": "*",
    "@types/bun": "1.3.9",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "rm -rf tsconfig.tsbuildinfo dist && tsc",
    "watch": "tsc --watch",
    "test": "bun test"
  }
}