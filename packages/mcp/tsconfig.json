{
  "compilerOptions": {
    "lib": ["ES2023"],
    "types": ["bun"],
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["bin/**/*.ts", "src/**/*.ts"],
  "exclude": ["src/tests/**"]
}
